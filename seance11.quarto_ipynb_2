      "source": [
        "#| echo: true\n",
        "#| eval: false\n",
        "\n",
        "def relu(x):\n",
        "    return np.maximum(0, x)\n",
        "\n",
        "def leaky_relu(x, alpha=0.01):\n",
        "    return np.where(x > 0, x, alpha * x)\n",
        "\n",
        "x = np.linspace(-10, 10, 1000)\n",
