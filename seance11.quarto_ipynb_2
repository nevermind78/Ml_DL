        "\n",
        "%% --- Entrées ---\n",
        "\\node[input neuron] (X1) at (0, 2*\\nodesep) {$x_1$};\n",
        "\\node[input neuron] (X2) at (0, 1*\\nodesep) {$x_2$};\n",
        "\\node[input neuron] (X3) at (0, 0)         {$x_3$};\n",
        "\n",
